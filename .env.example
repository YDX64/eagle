# AwaStats Data Service
# Single key used by every sport (football/basketball/hockey/volleyball/...).
# Obtain from your provider dashboard; never commit a real value.
AWASTATS_API_KEY=your_awastats_key_here
# Legacy alias — kept for backwards compatibility with older deploys
API_FOOTBALL_KEY=your_awastats_key_here

# Database
DATABASE_URL=file:./prisma/dev.db

# Next Auth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000