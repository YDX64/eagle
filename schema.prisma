model SportPrediction {
  id                    Int       @id @default(autoincrement())
  sport                 Sport
  game_id               Int
  prediction_type       String
  predicted_value       String
  confidence_score      Float
  is_high_confidence    Boolean   @default(false)
  confidence_tier       String?
  expected_value        Float?
  kelly_percentage      Float?
  market_odds           Float?
  implied_probability   Float?
  our_probability       Float?
  value_edge            Float?
  algorithm_version     String    @default("1.0")
  factors_used          Json?
  is_correct            Boolean?
  actual_result         String?
  reasoning             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([sport, is_high_confidence, confidence_score])
  @@index([sport, confidence_tier, createdAt])
  @@index([sport, game_id])
  @@map("sport_predictions")
}
model bb_backfill_jobs {
  id             BigInt    @id @default(autoincrement())
  job_type       String
  source         String
  target         String
  status         String    @default("pending")
  started_at     DateTime? @db.Timestamptz(6)
  finished_at    DateTime? @db.Timestamptz(6)
  progress_done  Int?      @default(0)
  progress_total Int?      @default(0)
  error_message  String?
  created_at     DateTime  @default(now()) @db.Timestamptz(6)

  @@index([status], map: "idx_bb_backfill_status")
  @@index([job_type], map: "idx_bb_backfill_type")
}

model bb_games {
  id             String   @id
  source         String
  api_game_id    Int
  league_id      Int
  league_name    String?
  season         String
  game_date      DateTime @db.Timestamptz(6)
  status_short   String?
  status_long    String?
  home_team_id   Int
  home_team_name String
  home_team_code String?
  away_team_id   Int
  away_team_name String
  away_team_code String?
  home_score     Int?
  away_score     Int?
  home_linescore Json?
  away_linescore Json?
  venue_name     String?
  venue_city     String?
  raw_data       Json?
  fetched_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([source, api_game_id], map: "idx_bb_games_api_id")
