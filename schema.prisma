model SportPrediction {
  id                    Int       @id @default(autoincrement())
  sport                 Sport
  game_id               Int
  prediction_type       String
  predicted_value       String
  confidence_score      Float
  is_high_confidence    Boolean   @default(false)
  confidence_tier       String?
  expected_value        Float?
  kelly_percentage      Float?
  market_odds           Float?
  implied_probability   Float?
  our_probability       Float?
  value_edge            Float?
  algorithm_version     String    @default("1.0")
  factors_used          Json?
  is_correct            Boolean?
  actual_result         String?
  reasoning             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([sport, is_high_confidence, confidence_score])
  @@index([sport, confidence_tier, createdAt])
  @@index([sport, game_id])
  @@map("sport_predictions")
}
