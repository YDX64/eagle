generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================================================
// EXISTING PRODUCTION TABLES (from probet DB) — DO NOT MODIFY
// ==========================================================================

model bb_backfill_jobs {
  id             BigInt    @id @default(autoincrement())
  job_type       String
  source         String
  target         String
  status         String    @default("pending")
  started_at     DateTime? @db.Timestamptz(6)
  finished_at    DateTime? @db.Timestamptz(6)
  progress_done  Int?      @default(0)
  progress_total Int?      @default(0)
  error_message  String?
  created_at     DateTime  @default(now()) @db.Timestamptz(6)

  @@index([status], map: "idx_bb_backfill_status")
  @@index([job_type], map: "idx_bb_backfill_type")
}

model bb_games {
  id             String   @id
  source         String
  api_game_id    Int
  league_id      Int
  league_name    String?
  season         String
  game_date      DateTime @db.Timestamptz(6)
  status_short   String?
  status_long    String?
  home_team_id   Int
  home_team_name String
  home_team_code String?
  away_team_id   Int
  away_team_name String
  away_team_code String?
  home_score     Int?
  away_score     Int?
  home_linescore Json?
  away_linescore Json?
  venue_name     String?
  venue_city     String?
  raw_data       Json?
  fetched_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([source, api_game_id], map: "idx_bb_games_api_id")
  @@index([away_team_id], map: "idx_bb_games_away_team")
  @@index([game_date], map: "idx_bb_games_date")
  @@index([home_team_id], map: "idx_bb_games_home_team")
  @@index([league_id, season], map: "idx_bb_games_league_season")
  @@index([source], map: "idx_bb_games_source")
  @@index([status_short], map: "idx_bb_games_status")
}

model bb_ml_models {
  id               BigInt    @id @default(autoincrement())
  source           String
  league_id        Int
  season           String
  model_type       String
  target           String
  model_data       Json
  feature_names    Json
  training_samples Int?
  cv_accuracy      Float?
  cv_log_loss      Float?
  cv_brier         Float?
  trained_at       DateTime  @default(now()) @db.Timestamptz(6)
  expires_at       DateTime? @db.Timestamptz(6)

  @@unique([source, league_id, season, model_type, target, trained_at])
  @@index([source, league_id, season, target, trained_at(sort: Desc)], map: "idx_bb_ml_models_lookup")
}

model bb_odds_snapshots {
  id               BigInt   @id @default(autoincrement())
  source           String
  game_id          String
  api_game_id      Int
  bookmaker        String
  snapshot_at      DateTime @default(now()) @db.Timestamptz(6)
  odds_data        Json
  home_moneyline   Float?
  away_moneyline   Float?
  spread_line      Float?
  spread_home_odds Float?
  total_line       Float?
  over_odds        Float?
  under_odds       Float?

  @@index([bookmaker], map: "idx_bb_odds_bookmaker")
  @@index([game_id], map: "idx_bb_odds_game")
  @@index([snapshot_at], map: "idx_bb_odds_snapshot_at")
}

model bb_player_game_logs {
  id             BigInt   @id @default(autoincrement())
  source         String   @default("nba")
  game_id        String
  api_game_id    Int
  player_id      Int
  player_name    String?
  team_id        Int
  team_name      String?
  minutes        Float?
  points         Int?
  fgm            Int?
  fga            Int?
  ftm            Int?
  fta            Int?
  tpm            Int?
  tpa            Int?
  off_reb        Int?
  def_reb        Int?
  total_reb      Int?
  assists        Int?
  steals         Int?
  blocks         Int?
  turnovers      Int?
  personal_fouls Int?
  plus_minus     Int?
  position       String?
  is_starter     Boolean?
  dnp            Boolean?
  fetched_at     DateTime @default(now()) @db.Timestamptz(6)

  @@unique([source, api_game_id, player_id])
  @@index([game_id], map: "idx_bb_player_logs_game")
  @@index([player_id], map: "idx_bb_player_logs_player")
  @@index([team_id], map: "idx_bb_player_logs_team")
}

model bb_player_season_averages {
  id             BigInt   @id @default(autoincrement())
  source         String   @default("nba")
  player_id      Int
  player_name    String?
  team_id        Int
  team_name      String?
  season         String
  games_played   Int      @default(0)
  games_started  Int?     @default(0)
  mpg            Float?
  ppg            Float?
  rpg            Float?
  apg            Float?
  spg            Float?
  bpg            Float?
  topg           Float?
  tpmpg          Float?
  tpapg          Float?
  fg_pct         Float?
  ft_pct         Float?
  tp_pct         Float?
  plus_minus_avg Float?
  usage_rate     Float?
  ppg_std        Float?
  rpg_std        Float?
  apg_std        Float?
  tpmpg_std      Float?
  correlations   Json?
  computed_at    DateTime @default(now()) @db.Timestamptz(6)

  @@unique([source, player_id, season])
  @@index([source, player_id, season], map: "idx_bb_player_season_lookup")
  @@index([team_id, season], map: "idx_bb_player_season_team")
}

model bb_quarter_shares {
  id           BigInt   @id @default(autoincrement())
  source       String
  league_id    Int
  season       String
  q1_share     Float
  q2_share     Float
  q3_share     Float
  q4_share     Float
  fh_share     Float
  sh_share     Float
  q1_std       Float?
  q2_std       Float?
  q3_std       Float?
  q4_std       Float?
  sample_games Int
  computed_at  DateTime @default(now()) @db.Timestamptz(6)

  @@unique([source, league_id, season])
  @@index([source, league_id, season], map: "idx_bb_quarter_shares_lookup")
}

model bb_team_ratings {
  id         BigInt   @id @default(autoincrement())
  source     String
  league_id  Int
  season     String
  team_id    Int
  as_of_date DateTime @db.Date
  elo        Float
  elo_games  Int      @default(0)
  off_mean   Float?
  off_var    Float?
  def_mean   Float?
  def_var    Float?
  massey     Float?
  composite  Float?
  home_adv   Float?   @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@unique([source, league_id, season, team_id, as_of_date])
  @@index([source, league_id, season, team_id, as_of_date(sort: Desc)], map: "idx_bb_ratings_current")
  @@index([as_of_date], map: "idx_bb_ratings_date")
}

model bb_team_season_aggregates {
  id             BigInt   @id @default(autoincrement())
  source         String
  league_id      Int
  season         String
  team_id        Int
  team_name      String?
  games_played   Int      @default(0)
  points         Int?
  points_allowed Int?
  fgm            Int?
  fga            Int?
  ftm            Int?
  fta            Int?
  tpm            Int?
  tpa            Int?
  off_reb        Int?
  def_reb        Int?
  assists        Int?
  steals         Int?
  blocks         Int?
  turnovers      Int?
  personal_fouls Int?
  efg_pct        Float?
  tov_pct        Float?
  orb_pct        Float?
  ft_rate        Float?
  opp_efg_pct    Float?
  opp_tov_pct    Float?
  opp_orb_pct    Float?
  opp_ft_rate    Float?
  pace           Float?
  off_rating     Float?
  def_rating     Float?
  net_rating     Float?
