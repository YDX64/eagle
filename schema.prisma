model pattern_matches {
  id               BigInt      @id @default(autoincrement())
  prediction_id    String
  pattern_id       String
  pattern_name     String?
  pattern_category String?
  hit_rate         Float?
  sample_size      Int?
  is_banko         Boolean?    @default(false)
  predicted_market String?
  hit              Boolean?
  predictions      predictions @relation(fields: [prediction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([hit], map: "idx_patterns_hit")
  @@index([pattern_id], map: "idx_patterns_id")
  @@index([prediction_id], map: "idx_patterns_prediction")
}

model picks {
  id                 BigInt      @id @default(autoincrement())
  prediction_id      String
  market             String
  market_label       String?
  pick_label         String?
  category           String?
  probability        Float?
  market_odds        Float?
  expected_value     Float?
  is_best            Boolean?    @default(false)
  is_high_confidence Boolean?    @default(false)
  hit                Boolean?
  score_value        String?
  predictions        predictions @relation(fields: [prediction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([hit], map: "idx_picks_hit")
  @@index([market], map: "idx_picks_market")
  @@index([prediction_id], map: "idx_picks_prediction")
}

model predictions {
  id                  String            @id
  sport               String            @default("football")
  fixture_id          Int
  home_team           String?
  away_team           String?
  league              String?
  match_date          DateTime?         @db.Timestamptz(6)
  predicted_at        DateTime          @default(now()) @db.Timestamptz(6)
  status              String            @default("pending")
  home_win_prob       Float?
  draw_prob           Float?
  away_win_prob       Float?
  confidence          Float?
  best_market         String?
  best_pick_label     String?
  best_probability    Float?
  best_market_odds    Float?
  best_expected_value Float?
  actual_home         Int?
  actual_away         Int?
  actual_ht_home      Int?
  actual_ht_away      Int?
  resolved_at         DateTime?         @db.Timestamptz(6)
  best_pick_hit       Boolean?
  payload             Json?
  pattern_matches     pattern_matches[]
  picks               picks[]
  system_bets         system_bets[]
  player_prop_picks   player_prop_picks[]

  @@index([fixture_id], map: "idx_predictions_fixture")
  @@index([match_date], map: "idx_predictions_match_date")
  @@index([predicted_at], map: "idx_predictions_predicted_at")
  @@index([sport], map: "idx_predictions_sport")
  @@index([status], map: "idx_predictions_status")
}

model system_bets {
  id                BigInt      @id @default(autoincrement())
  prediction_id     String
  market            String
  pick_label        String?
  model_probability Float?
  market_odds       Float?
  expected_value    Float?
  kelly_stake       Float?
  risk_level        String?
  category          String?
  hit               Boolean?
  predictions       predictions @relation(fields: [prediction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([category], map: "idx_system_bets_category")
  @@index([hit], map: "idx_system_bets_hit")
  @@index([prediction_id], map: "idx_system_bets_prediction")
}

// ==========================================================================
// NEW MULTI-SPORT TRACKING TABLES (v2 — cross-sport market tracking)
// ==========================================================================

/// Unified cross-sport fixture/game cache. Every sport writes here.
model sport_games {
  id              String   @id // "{sport}:{api_game_id}"
  sport           String
  api_game_id     Int
  league_id       Int?
  league_name     String?
  league_country  String?
  season          String?
  game_date       DateTime @db.Timestamptz(6)
  timestamp       Int?
  status_short    String?
  status_long     String?
  status_elapsed  Int?
  home_team_id    Int?
  home_team_name  String
  home_team_logo  String?
  away_team_id    Int?
  away_team_name  String
  away_team_logo  String?
  home_score      Int?
  away_score      Int?
  home_score_ht   Int?
  away_score_ht   Int?
  raw_scores      Json?
  venue_name      String?
  venue_city      String?
  raw_fixture     Json?
  fetched_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6) @updatedAt

  @@unique([sport, api_game_id])
  @@index([sport, game_date], map: "idx_sport_games_sport_date")
  @@index([game_date], map: "idx_sport_games_date")
  @@index([sport, league_id, game_date], map: "idx_sport_games_sport_league")
  @@index([status_short], map: "idx_sport_games_status")
}

/// Cross-sport odds snapshots (separate from bb_odds_snapshots which is NBA-only).
model odds_snapshots_v2 {
  id           BigInt   @id @default(autoincrement())
  sport        String
  api_game_id  Int
  game_id      String? // "{sport}:{api_game_id}"
  bookmaker_id Int?
  bookmaker    String
  market       String
  selection    String?
  line         Float?
  odds_value   Float
  is_opening   Boolean  @default(false)
  is_closing   Boolean  @default(false)
  snapshot_at  DateTime @default(now()) @db.Timestamptz(6)
  raw_data     Json?

  @@index([sport, api_game_id, market], map: "idx_odds_v2_sport_game_market")
  @@index([sport, api_game_id, bookmaker], map: "idx_odds_v2_sport_game_book")
  @@index([snapshot_at], map: "idx_odds_v2_snapshot_at")
  @@index([market, selection], map: "idx_odds_v2_market_selection")
}

/// Player-level prop predictions (basketball/hockey/baseball/football).
/// Linked to predictions via prediction_id when a game-level prediction exists.
model player_prop_picks {
  id                BigInt       @id @default(autoincrement())
  sport             String
  api_game_id       Int
  prediction_id     String? // optional: link to game-level prediction
  player_id         Int
  player_name       String
  team_id           Int?
  team_name         String?
  position          String?
  market            String // POINTS, REBOUNDS, ASSISTS, GOALS, SHOTS, STRIKEOUTS, HITS, etc.
  market_label      String?
  line              Float
  selection         String // OVER, UNDER, YES, NO
  pick_label        String?
  probability       Float
  market_odds       Float?
  expected_value    Float?
  is_high_confidence Boolean     @default(false)
  is_best           Boolean      @default(false)
  category          String?
  confidence_tier   String? // platinum, gold, silver
  reasoning         String?
  factors_used      Json?
  actual_value      Float?
  hit               Boolean?
  resolved_at       DateTime?    @db.Timestamptz(6)
  predicted_at      DateTime     @default(now()) @db.Timestamptz(6)
  predictions       predictions? @relation(fields: [prediction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sport, predicted_at(sort: Desc)], map: "idx_player_props_sport_time")
  @@index([sport, api_game_id], map: "idx_player_props_game")
  @@index([player_id], map: "idx_player_props_player")
  @@index([hit], map: "idx_player_props_hit")
  @@index([market, selection], map: "idx_player_props_market_selection")
  @@index([is_high_confidence, probability(sort: Desc)], map: "idx_player_props_high_conf")
}

/// Batch prediction run audit trail. Each daily/hourly orchestration run logs here.
model prediction_runs {
  id                 String    @id @default(cuid())
  run_type           String // daily, hourly, manual, backfill
  target_date        DateTime? @db.Date
  target_sports      Json // ["football", "basketball", ...]
  started_at         DateTime  @default(now()) @db.Timestamptz(6)
  finished_at        DateTime? @db.Timestamptz(6)
  status             String    @default("running") // running, completed, failed, partial
  fixtures_scanned   Int       @default(0)
  predictions_saved  Int       @default(0)
  picks_saved        Int       @default(0)
  player_props_saved Int       @default(0)
  odds_snapshots     Int       @default(0)
  errors             Json?
  meta               Json?

  @@index([run_type, started_at(sort: Desc)], map: "idx_prediction_runs_type_time")
  @@index([status], map: "idx_prediction_runs_status")
}

/// Cross-sport market taxonomy — unified names, categories, settlement rules.
model market_taxonomy {
  market_code       String  @id // e.g., "HOME_WIN", "UNDER_25", "BB_POINTS_OVER"
  sport             String // football, basketball, hockey, handball, volleyball, baseball, all
  family            String // match_winner, totals, handicap, btts, cards, corners, player_props, correct_score, ht_ft
  category          String // main, side, special, player
  display_name_tr   String // Turkish display name
  display_name_en   String // English display name
  description       String?
  settlement_rule   String // Pseudo-DSL: "home_score > away_score", "home_score + away_score > line"
  requires_line     Boolean @default(false)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6) @updatedAt

  @@index([sport, family], map: "idx_market_tax_sport_family")
  @@index([family, category], map: "idx_market_tax_family_cat")
}
