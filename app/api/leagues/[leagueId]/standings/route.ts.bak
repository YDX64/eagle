
import { NextRequest, NextResponse } from 'next/server';
import { ApiFootballService, CURRENT_SEASON } from '@/lib/api-football';
import { CacheService } from '@/lib/cache';

export const dynamic = "force-dynamic";

export async function GET(
  request: NextRequest,
  { params }: { params: Promise<{ leagueIdNum: string }> }
) {
  const { leagueId } = await params;
    try {
    const leagueIdNumNum = parseInt(leagueIdNum);
    const { searchParams } = new URL(request.url);
    const season = parseInt(searchParams.get('season') || CURRENT_SEASON.toString());
    
    if (isNaN(leagueIdNum)) {
      return NextResponse.json(
        { success: false, error: 'Invalid league ID' },
        { status: 400 }
      );
    }

    const cacheKey = CacheService.generateApiKey('standings', { leagueId: leagueIdNum, season });
    
    const standings = await CacheService.cacheApiResponse(
      cacheKey,
      async () => {
        return await ApiFootballService.getStandings(leagueIdNum, season);
      },
      CacheService.TTL.LEAGUE_STANDINGS
    );

    return NextResponse.json({
      success: true,
      data: standings,
      leagueIdNum,
      season
    });
  } catch (error) {
    console.error('Error fetching league standings:', error);
    return NextResponse.json(
      {
        success: false,
        error: 'Failed to fetch standings',
        message: error instanceof Error ? error.message : 'Unknown error'
      },
      { status: 500 }
    );
  }
}
